{
    "name": "newo-io/laravel-sdk",
    "description": "DEPRECATO — usa onesto-it/laravel-sdk. Questo pacchetto è un metapackage di compatibilità: installa onesto-it/laravel-sdk e mantiene attivi i vecchi nomi `Newo::` / `Newo\\Sdk\\` / `NEWO_TOKEN`.",
    "type": "library",
    "license": "MIT",
    "abandoned": "onesto-it/laravel-sdk",
    "keywords": ["onesto", "newo", "laravel", "sdk", "deprecated"],
    "support": {
        "issues": "https://github.com/Onesto-it/laravel-sdk/issues",
        "source": "https://github.com/Onesto-it/laravel-sdk"
    },
    "require": {
        "php": ">=8.1",
        "onesto-it/laravel-sdk": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Newo\\Sdk\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Newo\\Sdk\\NewoServiceProvider"
            ],
            "aliases": {
                "Newo": "Newo\\Sdk\\Facades\\Newo"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
